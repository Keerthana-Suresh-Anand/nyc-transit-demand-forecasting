# AWS credentials (create IAM user with S3 access only)
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_BUCKET_NAME=
AWS_REGION=us-east-1

# NYC Open Data app token (https://data.ny.gov/profile/app_tokens)
NY_APP_TOKEN=

# Visual Crossing weather API (https://www.visualcrossing.com/weather-api)
WEATHER_API_KEY=

# Ticketmaster API (https://developer.ticketmaster.com) — optional, for events overlay
TICKETMASTER_API_KEY=

# MLflow tracking URI (default: local SQLite, change for remote server)
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
